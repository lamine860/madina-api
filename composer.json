{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "intervention/image": "^4.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "*",
        "laravel/tinker": "^3.0",
        "nwidart/laravel-modules": "*",
        "spatie/laravel-medialibrary": "*"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "knuckleswtf/scribe": "^5.9",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.5",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\Core\\": "Modules/Core/app/",
            "Modules\\Core\\Database\\Factories\\": "Modules/Core/database/factories/",
            "Modules\\Core\\Database\\Seeders\\": "Modules/Core/database/seeders/",
            "Modules\\Shop\\": "Modules/Shop/app/",
            "Modules\\Shop\\Database\\Factories\\": "Modules/Shop/database/factories/",
            "Modules\\Shop\\Database\\Seeders\\": "Modules/Shop/database/seeders/",
            "Modules\\Catalog\\": "Modules/Catalog/app/",
            "Modules\\Catalog\\Database\\Factories\\": "Modules/Catalog/database/factories/",
            "Modules\\Catalog\\Database\\Seeders\\": "Modules/Catalog/database/seeders/",
            "Modules\\Cart\\": "Modules/Cart/app/",
            "Modules\\Cart\\Database\\Factories\\": "Modules/Cart/database/factories/",
            "Modules\\Cart\\Database\\Seeders\\": "Modules/Cart/database/seeders/",
            "Modules\\Orders\\": "Modules/Orders/app/",
            "Modules\\Orders\\Database\\Factories\\": "Modules/Orders/database/factories/",
            "Modules\\Orders\\Database\\Seeders\\": "Modules/Orders/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Modules\\Core\\Tests\\": "Modules/Core/tests/",
            "Modules\\Catalog\\Tests\\": "Modules/Catalog/tests/",
            "Modules\\Cart\\Tests\\": "Modules/Cart/tests/",
            "Modules\\Orders\\Tests\\": "Modules/Orders/tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
